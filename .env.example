# API_PORT: KneeJoy 后端 REST API 端口（默认 3001）
API_PORT=3001

# VITE_API_BASE: 留空或不写则默认 /api/v1（勿写 VITE_API_BASE= 空字符串，会致登录 404）
# VITE_API_BASE=/api/v1

# VITE_HARDWARE_MODE: mock = 模拟硬件；wifi = ESP32 局域网 HTTP；mqtt = EMQX Cloud（手机演示推荐）
VITE_HARDWARE_MODE=mqtt

# --- MQTT（VITE_HARDWARE_MODE=mqtt 时必填，复制为 .env.local 并填入密钥）---
# 用户名/密码来自 EMQX 控制台「访问控制 → 认证」（不是 App ID/Secret）
# EMQX Serverless WebSocket（浏览器）
VITE_MQTT_URL=wss://ae98d3ea.ala.cn-hangzhou.emqxsl.cn:8084/mqtt
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
# 设备 ID：串口日志 mqtt: connected, id=kj_xxxxxxxxxxxx
VITE_DEVICE_ID=kj_d885ac8d1872
# VITE_MQTT_TOPIC_PREFIX=kneejoy

# --- 局域网 HTTP 备用（VITE_HARDWARE_MODE=wifi）---
# VITE_DEVICE_IP=192.168.1.100
# DEVICE_IP=192.168.1.100

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
